{
  "expo": {
    "name": "splytr",
    "slug": "splytr",
    "owner": "manpreetnub23",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "splytr",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon.png",
        "backgroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.manpreetnub23.splytr"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "apiBaseUrl": "http://localhost:8000/api",
      "apiBaseUrlAndroid": "http://10.0.2.2:8000/api",
      "apiBaseUrlIos": "http://localhost:8000/api",
      "apiBaseUrlWeb": "http://localhost:8000/api",
      "googleExpoClientId": "486719074874-ogh4ll0self5oi8qh1t3uc23998kjh7k.apps.googleusercontent.com",
      "googleIosClientId": "",
      "googleAndroidClientId": "486719074874-ogh4ll0self5oi8qh1t3uc23998kjh7k.apps.googleusercontent.com",
      "googleWebClientId": "486719074874-ogh4ll0self5oi8qh1t3uc23998kjh7k.apps.googleusercontent.com"
    }
  }
}
